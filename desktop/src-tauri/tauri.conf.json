{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fognitix",
  "version": "0.1.0",
  "identifier": "com.fognitix.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Fognitix",
        "width": 1400,
        "height": 880,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "msi"
  }
}
